# =============================================================================
# Qlawkus — Environment Configuration
# Copy this file to .env and fill in the values
#   cp .env.example .env
# =============================================================================

# --- LLM provider ----------------------------------------------------------
# The provider profile (kind) sets the base URL + chat/embedding models + dims.
# Kinds: openai, nvidia, deepseek, mistral, groq, xai, openrouter
# NVIDIA key at https://build.nvidia.com/  (do NOT commit .env to git)
LLM_KIND=nvidia
LLM_API_KEY=
# Optional overrides — leave unset to use the kind's defaults:
# LLM_CHAT_MODEL=
# LLM_EMBEDDING_MODEL=
# EMBEDDING_DIMENSION=
# LLM_BASE_URL=
# Different provider just for embeddings (e.g. chat=groq, embeddings=openai):
# LLM_EMBEDDING_KIND=

# --- API Authentication ----------------------------------------------------
API_USER_PASSWORD=qlawkus

# --- PostgreSQL (Docker Compose) -------------------------------------------
# Used by both docker-compose.yml and docker-compose.local.yml
POSTGRES_DB=qlawkus
POSTGRES_USER=qlawkus
POSTGRES_PASSWORD=qlawkus

# --- Production Datasource (docker-compose.yml) ----------------------------
# Override these only if you point to an external Postgres
QUARKUS_DATASOURCE_JDBC_URL=jdbc:postgresql://localhost:5432/qlawkus
QUARKUS_DATASOURCE_USERNAME=qlawkus
QUARKUS_DATASOURCE_PASSWORD=qlawkus

# --- Ollama (local / docker-compose.local.yml) -----------------------------
# Dev mode (quarkus dev) uses Dev Services — ignore these.
# Only relevant when running docker-compose.local.yml. Also drives the
# Ollama fallback. mxbai-embed-large is 1024 dims (matches EMBEDDING_DIMENSION).
# OLLAMA_MODEL=qwen3.5:4b
# OLLAMA_EMBEDDING_MODEL=mxbai-embed-large

DISCORD_BOT_TOKEN=
DISCORD_APP_ID=

GROQ_API_KEY=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

QLAWKUS_VAULT_PASSPHRASE=

TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=
