# =============================================================================
# Qlawkus — Environment Configuration
# Copy this file to .env and fill in the values
#   cp .env.example .env
# =============================================================================

# --- Production (NVIDIA NIM) -----------------------------------------------
# Get your API key at https://build.nvidia.com/
# Set it in your shell: export NVIDIA_AI_API_KEY=nvapi-xxxx
# Or paste below (do NOT commit .env to git)
NVIDIA_AI_API_KEY=
NVIDIA_CHAT_MODEL=z-ai/glm-5.1
NVIDIA_EMBEDDING_MODEL=nvidia/nv-embedqa-e5-v5
EMBEDDING_DIMENSION=1024

# --- API Authentication ----------------------------------------------------
API_USER_PASSWORD=qlawkus

# --- PostgreSQL (Docker Compose) -------------------------------------------
# Used by both docker-compose.yml and docker-compose.local.yml
POSTGRES_DB=qlawkus
POSTGRES_USER=qlawkus
POSTGRES_PASSWORD=qlawkus

# --- Production Datasource (docker-compose.yml) ----------------------------
# Override these only if you point to an external Postgres
QUARKUS_DATASOURCE_JDBC_URL=jdbc:postgresql://localhost:5432/qlawkus
QUARKUS_DATASOURCE_USERNAME=qlawkus
QUARKUS_DATASOURCE_PASSWORD=qlawkus

# --- Ollama (local / docker-compose.local.yml) -----------------------------
# Dev mode (quarkus dev) uses Dev Services — ignore these
# Only relevant when running docker-compose.local.yml
OLLAMA_MODEL=gemma4:e2b
OLLAMA_EMBEDDING_MODEL=mxbai-embed-large
