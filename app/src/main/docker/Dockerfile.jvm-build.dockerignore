# Ignore file for the in-container source build (Dockerfile.jvm-build). BuildKit
# uses this instead of the standard .dockerignore, which is tuned for the
# COPY-target build and would exclude src/. Patterns are relative to the repo root.
**/target
.git
.gitignore
**/*.iml
.idea
.vscode
node_modules
*.log
.env
.env.*
.qlawkus
site/public
